ANTHROPIC_API_KEY=your_anthropic_api_key_here
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_ADDRESS=Vomni <bookings@vomni.app>
ADMIN_PASSWORD=vomni_admin_2026
NEXT_PUBLIC_APP_URL=https://your-vercel-url.vercel.app

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Webhook security (optional — set the same value in Supabase webhook config)
SUPABASE_WEBHOOK_SECRET=your_webhook_secret_here

# ── Booking Platform ─────────────────────────────────────────────────────────

# AES-256-GCM key for encrypting calendar OAuth tokens
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CALENDAR_TOKEN_SECRET=your_64_char_hex_string_here

# Google Calendar OAuth
# Create at: console.cloud.google.com → APIs → Credentials → OAuth 2.0 Client
# Enable "Google Calendar API", set redirect URI:
#   https://your-app.vercel.app/api/google-calendar/callback
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_secret_here

# Microsoft Outlook Calendar OAuth
# Create at: portal.azure.com → App registrations
# Add permission: Calendars.Read + offline_access
# Set redirect URI: https://your-app.vercel.app/api/calendar/outlook/callback
MICROSOFT_CLIENT_ID=your_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret
MICROSOFT_TENANT_ID=common

# Web Push (PWA push notifications)
# Generate VAPID keys: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
